url <- 'https://raw.githubusercontent.com/databrew/intro-to-data-science/main/data/coughs.csv'
coughs <- read_csv(url)
coughs <-
coughs %>%
select(-recording_device) %>%
select(-prediction_score)
#####
# A. Create a dow (day of week) column.
d_t <- coughs$date_time
d_t <- d_t %>% as_datetime
coughs$date_time <- d_t
coughs <-
coughs %>%
mutate(dow = date_time %>% weekdays)
tt(coughs %>% head)
#####
# B. Create a date (without time) column.
coughs <-
coughs %>%
mutate(date = date_time %>% as_date)
tt(coughs %>% head)
#####
# C. How many coughs happened each day?
ncoughs <-
coughs %>%
filter(is_cough == TRUE) %>%
group_by(date) %>%
summarize(`number of coughs per day` = n())
tt(ncoughs)
#####
# D. Create a chart of coughs for each day.
ggplot(ncoughs,
aes(y = `number of coughs per day`,
x = date,
fill = date))+
geom_col()+
labs(title = 'Number of Coughs per Day ',
y='Number or Coughs',
x = 'Date',
fill = 'Date')
#####
# E. Get the number of coughs by date-hour.
d_h <- coughs$date_time
d_h <- d_h %>% as_datetime
d_h <- round_date(d_h, unit='hours')
coughs$date_time <- d_h
ncoughs.date.hour <-
coughs %>%
filter(is_cough == TRUE) %>%
group_by(date_time) %>%
summarize(`number of coughs by date-hour` = n())
tt(ncoughs.date.hour)
#####
# F. Create an hour column.
coughs <-
coughs %>%
mutate(hour = d_h %>% hour)
tt(coughs %>% head)
#####
# G. Use the hour column to create a night_day column indicating whether the cough
#was occurring at night or day. Assume night begins at 7pm and ends at 7am.
dayy <- c(7:19)
nightt <- c(20:24, 1:6)
h <- coughs$hour
coughs <-
coughs %>%
mutate(night_day = case_when(
h %in% dayy ~ 'day',
h %in% nightt ~ 'night'))
coughs <-
coughs %>%
filter(night_day %in% c('day','night'))
tt(coughs %>% head)
#####
# H. Make a plot to answer whether this child coughed more at night or day.
nightdaycoughs <-
coughs %>%
filter(is_cough == TRUE) %>%
group_by(night_day) %>%
summarise(total_c = n())
ggplot(nightdaycoughs,
aes(y = night_day,
x = total_c,
fill = night_day))+
geom_col()+
labs(title = 'Number of Coughs at Night vs. at Day',
subtitle = "Children coughed more in the day than at night",
y='Time of Day',
x = 'Number of Coughs',
fill = 'Time of Day')
url <- 'https://docs.google.com/spreadsheets/d/1P7a20daNtfTHP09nVFNAKm6ia_1l1XKKJ_5WZlSVTpA/edit?usp=sharing'
surv <- gsheet2tbl(url)
surv <- surv %>%
rename( at25 = `What do you expect your annual income to be when you are 25?`,
at35 = `What do you expect your annual income to be when you are 35?`,
at55 = `What do you expect your annual income to be when you are 55?`,
friz = `Who can throw a frisbee farther: John Benson or Eric Ezell?`,
time = `What time is it right now?`,
gender = `Your gender:`) %>%
filter(gender != "attack helicopter") %>%
mutate(friz = friz %>% tolower)
# format the friz question
friz <- surv$friz
friz <- gsub('john', '', friz)
friz <- gsub('eric', '', friz)
friz <- gsub(', sorry dr. ezell.', '', friz)
friz <- gsub('probably  b', 'b', friz)
friz <- gsub('probably', 'ezell', friz)
friz <- gsub(' ', '', friz)
surv$friz <- friz
# format the time
time <- surv$time
time <- time %>% tolower
time <- gsub('1:41', '13:41', time)
time <- gsub('1:40 pm', '13:40', time)
time <- gsub('2:48 p.m.', '14:48', time)
time <- gsub('4:14 pm', '16:14', time)
time <- gsub('5:02 pm', '17:02', time)
time <- gsub('6:19 pm', '18:19', time)
time <- gsub('6:50 pm', '18:50', time)
time <- gsub('9:42pm', '21:42', time)
time <- gsub('09:30 pm', '21:30', time)
time <- gsub('10:58 pm', '22:58', time)
time <- gsub('11:32pm', '23:32', time)
time <- gsub('8:11', '08:11', time)
time <- gsub('9:42', '09:42', time)
time <- gsub('9:45', '09:45', time)
time <- gsub(' am', '', time)
surv$time <- time
surv <-
surv %>%
mutate(hourss = substr(time, 1, 2))
lots <-
surv %>%
group_by(hourss) %>%
summarise(responces = n())
tt(lots) %>%
setNames(c("Time of Day", "Number of Reponces in the Hour"))
ggplot(lots,
aes(y = hourss,
x = responces,
fill = hourss))+
geom_col()+
labs(title = 'Number of Reponces Throughout the Day',
y='Time of Day',
x = 'Number of Reponces in the Hour',
fill = 'Time of Day')
kable(lots,
col.names = c("Time of Day", "Number of Reponces in the Hour")
kable(lots,
kable(lots,
col.names = c("Time of Day",
"Number of Reponces in the Hour"))
