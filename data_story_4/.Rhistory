library(dplyr)
library(ggplot2)
library(gapminder)
library(readr)
library(stringr)
library(lubridate)
library(gsheet)
library(tinytable)
df <- data.frame(first_name = c('Leonardo', 'Adam', 'Matt'),
last_name = c('Dicaprio', 'Sandler', 'Damon'),
bday = c('1974-11-11', '1966/9/9', '70-10-08'))
#####
# Format the Dates
birthday <- df$bday %>% as_date
y <- birthday %>% year
m <- str_pad(birthday %>% month, width=2, side='left', pad='0')
d <- str_pad(birthday %>% day, width=2, side='left', pad='0')
birthday <-
paste0( m,'-', d, '-', y )
#####
# Format the First Names
first <- df$first_name
first <- substr(first, 1, 1)
#####
# Select and order the columns
df <-
df %>%
mutate(celebrity = paste0(first,'. ', last_name)) %>%
mutate(bday = birthday) %>%
select(celebrity, bday)
#####
# Print!
print(df)
```
df <- data.frame(first_name = c('Leonardo', 'Adam', 'Matt'),
last_name = c('Dicaprio', 'Sandler', 'Damon'),
bday = c('1974-11-11', '1966/9/9', '70-10-08'))
#####
# Format the Dates
birthday <- df$bday %>% as_date
y <- birthday %>% year
m <- str_pad(birthday %>% month, width=2, side='left', pad='0')
d <- str_pad(birthday %>% day, width=2, side='left', pad='0')
birthday <-
paste0( m,'-', d, '-', y )
#####
# Format the First Names
first <- df$first_name
first <- substr(first, 1, 1)
#####
# Select and order the columns
df <-
df %>%
mutate(celebrity = paste0(first,'. ', last_name)) %>%
mutate(bday = birthday) %>%
select(celebrity, bday)
#####
# Print!
print(df)
url <- 'https://docs.google.com/spreadsheets/d/1P7a20daNtfTHP09nVFNAKm6ia_1l1XKKJ_5WZlSVTpA/edit?usp=sharing'
surv <- gsheet2tbl(url)
surv <- surv %>%  rename( at25 = `What do you expect your annual income to be when you are 25?`,
at35 = `What do you expect your annual income to be when you are 35?`,
at55 = `What do you expect your annual income to be when you are 55?`,
gender = `Your gender:`) %>%
select(gender, at25, at35, at55) %>%
mutate( gender = gender %>% tolower) %>%
filter(gender != "attack helicopter")
#### #### #### #### #### #### #### #### #### #### #### #### #### #### #### ####
#### Work on the money
# store column as a vector
at25 <- surv$at25
# work on it
at25 <- gsub('\\$', '', at25)
at25 <- gsub(',', '', at25)
at25 <- gsub('k', '000', at25)
at25 <- gsub('k', '000', at25)
at25 <- gsub('less than zero', '0', at25)
splits <- strsplit(at25, ' ')
at25 <- sapply(splits, '[[', 1) # keeps the first part of the "split"
at25 <- at25 %>% as.numeric
# save it back into data
surv$at25 <- at25
at35 <- surv$at35
# work on it
at35 <- gsub('\\$', '', at35)
at35 <- gsub(',', '', at35)
at35 <- gsub('k', '000', at35)
at35 <- gsub('k', '000', at35)
at35 <- gsub('less than zero', '0', at35)
splits <- strsplit(at35, ' ')
at35 <- sapply(splits, '[[', 1) # keeps the first part of the "split"
at35 <- at35 %>% as.numeric
# save it back into data
surv$at35 <- at35
at55 <- surv$at55
# work on it
at55 <- gsub('\\$', '', at55)
at55 <- gsub(',', '', at55)
at55 <- gsub('k', '000', at55)
at55 <- gsub('k', '000', at55)
at55 <- gsub('less than zero', '0', at55)
at55 <- gsub('(inflation)', '', at55)
splits <- strsplit(at55, ' ')
at55 <- sapply(splits, '[[', 1) # keeps the first part of the "split"
at55 <- at55 %>% as.numeric
# save it back into data
surv$at55 <- at55
#### #### #### #### #### #### #### #### #### #### #### #### #### #### #### ####
#### Work on the gender
# store column as a vector
gender <- surv$gender
# work on it
gender <- gsub('woman', 'female', gender)
gender <- gsub('man', 'male', gender)
# save it back into data
surv$gender <- gender
#### #### #### #### #### #### #### #### #### #### #### #### #### #### #### ####
#### Make a graph
avg_income <-
surv %>%
group_by(gender) %>%
summarize(`average income at 25` = mean(at25, na.rm = TRUE),
`average income at 35` = mean(at35, na.rm = TRUE),
`average income at 55` = mean(at55, na.rm = TRUE))
tt(avg_income)
ggplot(avg_income,
aes(y = `average income at 25`,
x = gender,
fill = gender))+
geom_col()+
labs(title = 'Female vs Male Expected income at 25',
y='Average Expected Income',
x = 'Gender',
fill = 'Gender')
ggplot(avg_income,
aes(y = `average income at 35`,
x = gender,
fill = gender))+
geom_col()+
labs(title = 'Female vs Male Expected income at 35',
y='Average Expected Income',
x = 'Gender',
fill = 'Gender')
ggplot(avg_income,
aes(y = `average income at 55`,
x = gender,
fill = gender))+
geom_col()+
labs(title = 'Female vs Male Expected income at 55',
y='Average Expected Income',
x = 'Gender',
fill = 'Gender')
