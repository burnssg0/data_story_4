at35 <- gsub(',', '', at35)
at35 <- gsub('k', '000', at35)
at35 <- gsub('k', '000', at35)
at35 <- gsub('less than zero', '0', at35)
splits <- strsplit(at35, ' ')
at35 <- sapply(splits, '[[', 1) # keeps the first part of the "split"
at35 <- at35 %>% as.numeric
# save it back into data
surv$at35 <- at35
at55 <- surv$at55
# work on it
at55 <- gsub('\\$', '', at55)
at55 <- gsub(',', '', at55)
at55 <- gsub('k', '000', at55)
at55 <- gsub('k', '000', at55)
at55 <- gsub('less than zero', '0', at55)
at55 <- gsub('(inflation)', '', at55)
splits <- strsplit(at55, ' ')
at55 <- sapply(splits, '[[', 1) # keeps the first part of the "split"
at55 <- at55 %>% as.numeric
# save it back into data
surv$at55 <- at55
#### #### #### #### #### #### #### #### #### #### #### #### #### #### #### ####
#### Work on the gender
# store column as a vector
gender <- surv$gender
# work on it
gender <- gsub('woman', 'female', gender)
gender <- gsub('man', 'male', gender)
# save it back into data
surv$gender <- gender
#### #### #### #### #### #### #### #### #### #### #### #### #### #### #### ####
#### Make a graph
avg_income <-
surv %>%
group_by(gender) %>%
summarize(`average income at 25` = mean(at25, na.rm = TRUE),
`average income at 35` = mean(at35, na.rm = TRUE),
`average income at 55` = mean(at55, na.rm = TRUE))
tt(avg_income)
